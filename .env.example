# ==================== 方舟官方 API ====================
# 【必需】方舟 API Key (https://console.volcengine.com/ark)
# 整个系统只使用这一把 Key, 普通用户在前端看不见、无法修改
# 服务启动时若未配置此变量将直接失败退出 (fail-fast)
ARK_API_KEY=

# ==================== Luminia API（主用，火山 ark 作应急备用）====================
# https://luapi.hagoot.com ；见 doc/Luminia说明/api.md
LUMINIA_API_KEY=
LUMINIA_API_BASE_URL=https://luapi.hagoot.com
# 平台开关也可在管理后台「全局设置」中配置（provider_ark_enabled / provider_luminia_enabled）

# Express 服务端口
PORT=3901

# ==================== 僵尸 generating 清扫（可选）====================
# 无 submit_id 超过 N 分钟仍无 video_url → 自动标 error（默认 50）
# STALE_GENERATING_NO_SUBMIT_MINUTES=50
# 已有 submit_id 但 updated_at 超过 N 分钟未变 → 自动标 error（默认 100，需大于方舟轮询约 60 分钟）
# STALE_GENERATING_WITH_SUBMIT_MINUTES=100
# 定时清扫间隔毫秒（默认 600000 = 10 分钟，最小 60000）
# STALE_GENERATING_SWEEP_INTERVAL_MS=600000

# ==================== 邮件服务 (SMTP) ====================
# 配置后，注册时发送验证码会通过邮件发送给用户
# 常见示例：
# - QQ 邮箱：SMTP_HOST=smtp.qq.com  SMTP_PORT=465  SMTP_SECURE=true
# - 163 邮箱：SMTP_HOST=smtp.163.com SMTP_PORT=465  SMTP_SECURE=true
# - Gmail:     SMTP_HOST=smtp.gmail.com SMTP_PORT=587  SMTP_SECURE=false

# SMTP_HOST=smtp.qq.com
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=your-email@qq.com
# SMTP_PASS=your-app-password
# SMTP_FROM=your-email@qq.com

# ==================== TOS 对象存储 ====================
# 缓存桶：视频/音频临时素材，供方舟下载；带本地 SQLite 去重与短 TTL 语义（勿与持久桶混用生命周期）
# 持久桶：YUN/SD 长期资产（与缓存池分离；持久上传逻辑可逐步接入）
# 在火山引擎控制台创建 TOS 桶 (私有读写),获取 AK/SK；region/endpoint 两桶通常一致
TOS_ACCESS_KEY_ID=
TOS_SECRET_ACCESS_KEY=
TOS_REGION=cn-guangzhou
TOS_ENDPOINT=tos-cn-guangzhou.volces.com
TOS_CACHE_BUCKET=seedance-cache
TOS_PERSIST_BUCKET=yun-lib
# 任务归档 HTML 写入持久桶（默认开启；需已配置 TOS_PERSIST_BUCKET）。关闭则仍落盘 server/data/archives/
# ARCHIVE_PERSIST_ENABLED=1
# 成片落持久桶（默认开启；关闭则仅保留方舟 video_url）
# VIDEO_RESULT_HOSTING_ENABLED=1

# === 开发脚本 dev.ps1：FFmpeg 工具容器（首帧缩略图等，见 docker-compose.ffmpeg.yml）===
# 无法使用 Docker 时设为 1 以跳过（相关功能不可用）：MODELTOOSD_SKIP_DOCKER_FFMPEG=1

# ==================== Studio API 集成（ModelTooYUN 代提交视频）====================
# 与 studio-api 的 SD_INTEGRATION_TOKEN 保持一致；留空则禁用 Bearer 集成鉴权（仅用浏览器 Session）。
# STUDIO_INTEGRATION_USER_EMAIL 必须是本库已存在的活跃用户邮箱（任务归属该用户，便于在 SD 后台溯源）。
# STUDIO_INTEGRATION_TOKEN=
# 须与 token 同时配置：users 表中 status=active 的 email（任务归属该账号）
# STUDIO_INTEGRATION_USER_EMAIL=studio-bridge@yourcompany.local

# ==================== ModelToo 统计代理（SD 管理后台按分组筛选）====================
# MODELTOO_API_URL=http://localhost:18110
# 任选其一：① 固定 JWT（易过期） ② 管理员用户名密码（推荐，服务端自动登录并缓存 token）
# MODELTOO_ADMIN_TOKEN=
# MODELTOO_ADMIN_USERNAME=admin
# MODELTOO_ADMIN_PASSWORD=

# ==================== ModelToo 预算系统（项目选择和余额显示）====================
# ModelToo 内部 API Token（用于调用 /internal/projects-with-balance）
# 与 ModelToo 服务器的 INTERNAL_API_TOKEN 保持一致
# VITE_MODELTOO_INTERNAL_TOKEN=
