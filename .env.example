# ==================== 方舟官方 API ====================
# 【必需】方舟 API Key (https://console.volcengine.com/ark)
# 整个系统只使用这一把 Key, 普通用户在前端看不见、无法修改
# 服务启动时若未配置此变量将直接失败退出 (fail-fast)
ARK_API_KEY=

# Express 服务端口
PORT=3901

# ==================== 邮件服务 (SMTP) ====================
# 配置后，注册时发送验证码会通过邮件发送给用户
# 常见示例：
# - QQ 邮箱：SMTP_HOST=smtp.qq.com  SMTP_PORT=465  SMTP_SECURE=true
# - 163 邮箱：SMTP_HOST=smtp.163.com SMTP_PORT=465  SMTP_SECURE=true
# - Gmail:     SMTP_HOST=smtp.gmail.com SMTP_PORT=587  SMTP_SECURE=false

# SMTP_HOST=smtp.qq.com
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=your-email@qq.com
# SMTP_PASS=your-app-password
# SMTP_FROM=your-email@qq.com

# ==================== TOS 对象存储 ====================
# 用于将视频/音频文件上传到 TOS,生成公网可访问的预签名 URL
# 供方舟 Content Generation API 下载素材
# 在火山引擎控制台创建 TOS 桶 (私有读写),获取 AK/SK
TOS_ACCESS_KEY_ID=
TOS_SECRET_ACCESS_KEY=
TOS_REGION=cn-guangzhou
TOS_ENDPOINT=tos-cn-guangzhou.volces.com
TOS_BUCKET=seedance-cache
